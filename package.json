{
  "name": "paste-to-docs",
  "version": "0.1.0",
  "description": "Paste from Claude, ChatGPT, or Gemini — download a clean .docx file",
  "scripts": {
    "icons": "node extension/icons/generate-icons.js",
    "lint": "eslint extension/content.js extension/popup.js",
    "pack": "zip -r paste-to-docs.zip extension/",
    "start": "npx serve ."
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "sharp": "^0.33.0"
  },
  "keywords": [
    "claude",
    "chatgpt",
    "gemini",
    "google-docs",
    "markdown",
    "docx",
    "productivity",
    "formatting"
  ],
