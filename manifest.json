{
  "manifest_version": 3,
  "name": "paste-to-docs",
  "version": "0.1.0",
  "description": "Paste from Claude, ChatGPT, or Gemini into Google Docs with perfect formatting. No extra clicks.",
  "permissions": [
    "clipboardRead",
    "clipboardWrite",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://docs.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
